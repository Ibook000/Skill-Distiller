# DEEPSEEK_API_KEY: Preferred default API key for DeepSeek requests.
# OPENAI_API_KEY: Backward-compatible alias for OpenAI-compatible requests.
# You can also enter the key manually in the app settings dialog.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
OPENAI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: OpenAI API Key if using OpenAI provider
OPENAI_API_KEY=""
